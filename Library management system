package Main;
import java.util.*;
import java.io.*;
class Book {
    int id;
    String name;
    boolean issued;
    Book(int id, String name) {
        this.id = id;
        this.name = name;
        this.issued = false;
    }
}
public class Main {
    static Book books[] = new Book[100];
    static int count = 0;
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
        int choice;
        do {
            System.out.println("\n--- LIBRARY SYSTEM ---");
            System.out.println("1. Add Book");
            System.out.println("2. Issue Book");
            System.out.println("3. Return Book");
            System.out.println("4. Display Books");
            System.out.println("5. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();
            switch (choice) {
                case 1:
                    addBook(sc);
                    break;
                case 2:
                    issueBook(sc);
                    break;
                case 3:
                    returnBook(sc);
                    break;
                case 4:
                    displayBooks();
                    break;
                case 5:
                    saveToFile();
                    System.out.println("Saved to file. Exiting...");
                    break;
                default:
                    System.out.println("Invalid choice");
            }
        } while (choice != 5);
    }
    static void addBook(Scanner sc) {
        System.out.print("Enter Book ID: ");
        int id = sc.nextInt();
        sc.nextLine();
        System.out.print("Enter Book Name: ");
        String name = sc.nextLine();
        books[count] = new Book(id, name);
        count++;
        System.out.println("Book Added!");
    }
    static void issueBook(Scanner sc) {
        System.out.print("Enter Book ID to issue: ");
        int id = sc.nextInt();
        for (int i = 0; i < count; i++) {
            if (books[i].id == id) {
                if (!books[i].issued) {
                    books[i].issued = true;
                    System.out.println("Book Issued!");
                } else {
                    System.out.println("Already issued");
                }
                return;
            }
        }
        System.out.println("Book not found");
    }
    static void returnBook(Scanner sc) {
        System.out.print("Enter Book ID to return: ");
        int id = sc.nextInt();
        for (int i = 0; i < count; i++) {
            if (books[i].id == id) {
                if (books[i].issued) {
                    books[i].issued = false;
                    System.out.println("Book Returned!");
                } else {
                    System.out.println("Book was not issued");
                }
                return;
            }
        }
        System.out.println("Book not found");
    }
    static void displayBooks() {
        for (int i = 0; i < count; i++) {
            System.out.println(books[i].id + " - " + books[i].name +
                    (books[i].issued ? " (Issued)" : " (Available)"));
        }
    }
    static void saveToFile() throws Exception {
        FileWriter fw = new FileWriter("library.txt");
        for (int i = 0; i < count; i++) {
            fw.write(books[i].id + "," + books[i].name + "," + books[i].issued + "\n");
        }
        fw.close();
    }
}
