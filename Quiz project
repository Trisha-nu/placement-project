package Main;
import javax.swing.*;
public class Main extends JFrame implements ActionListener {
    JLabel questionLabel, resultLabel;
    JRadioButton op1, op2, op3, op4;
    JButton nextButton;
    ButtonGroup bg;
    int index = 0, score = 0;
    String questions[] = {
        "Which language is used for Java?",
        "Which is not OOP concept?",
        "Which keyword is used for inheritance?"
    };
    String options[][] = {
        {"C", "Java", "Python", "HTML"},
        {"Encapsulation", "Polymorphism", "Compilation", "Inheritance"},
        {"this", "super", "extends", "implements"}
    };
    int answers[] = {1, 2, 2};
    Main() {
        setTitle("Smart Quiz System");
        setSize(500, 300);
        setLayout(new FlowLayout());
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        questionLabel = new JLabel();
        op1 = new JRadioButton();
        op2 = new JRadioButton();
        op3 = new JRadioButton();
        op4 = new JRadioButton();
        bg = new ButtonGroup();
        bg.add(op1);
        bg.add(op2);
        bg.add(op3);
        bg.add(op4);
        nextButton = new JButton("Next");
        resultLabel = new JLabel("");
        add(questionLabel);
        add(op1);
        add(op2);
        add(op3);
        add(op4);
        add(nextButton);
        add(resultLabel);
        nextButton.addActionListener(this);
        loadQuestion();
        setVisible(true);
    }
    void loadQuestion() {
        if (index < questions.length) {
            questionLabel.setText(questions[index]);
            op1.setText(options[index][0]);
            op2.setText(options[index][1]);
            op3.setText(options[index][2]);
            op4.setText(options[index][3]);
            bg.clearSelection();
        } else {
            showResult();
        }
    }
    public void actionPerformed(ActionEvent e) {
        int selected = -1;
        if (op1.isSelected()) selected = 0;
        if (op2.isSelected()) selected = 1;
        if (op3.isSelected()) selected = 2;
        if (op4.isSelected()) selected = 3;
        if (selected == answers[index]) {
            score++;
        }
        index++;
        loadQuestion();
    }
    void showResult() {
        String feedback;
        if (score == questions.length)
            feedback = "Excellent! 🎉";
        else if (score >= 2)
            feedback = "Good Job 👍";
        else
            feedback = "Needs Improvement ⚠️";
        resultLabel.setText("Score: " + score + "/" + questions.length + " - " + feedback);
    }
    public static void main(String[] args) {
        new Main();
    }
}
