package Main;
import java.util.*;
public class Main {
    static int MAX = 10;
    static ArrayList<Integer>[] graph = new ArrayList[MAX];
    public static void main(String[] args) {
        for (int i = 0; i < MAX; i++) {
            graph[i] = new ArrayList<>();
        }
        addEdge(0, 1);
        addEdge(0, 2);
        addEdge(1, 3);
        addEdge(2, 4);
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter user ID (0-4): ");
        int user = sc.nextInt();
        suggestFriends(user);
    }
    static void addEdge(int u, int v) {
        graph[u].add(v);
        graph[v].add(u);
    }
    static void suggestFriends(int start) {
        boolean visited[] = new boolean[MAX];
        Queue<Integer> q = new LinkedList<>();
        visited[start] = true;
        q.add(start);
        System.out.println("Friend Suggestions:");
        while (!q.isEmpty()) {
            int node = q.poll();
            for (int neighbor : graph[node]) {
                if (!visited[neighbor]) {
                    visited[neighbor] = true;
                    q.add(neighbor);
                    if (node != start) {
                        System.out.println("User " + neighbor);
                    }
                }
            }
        }
    }
}
